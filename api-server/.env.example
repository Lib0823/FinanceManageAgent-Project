# api-server environment template (NAMES ONLY — never commit real values)
# Copy to .env (git-ignored) and fill in, or export before `./gradlew bootRun`.

# DART (금융감독원 전자공시) Open API key — enables 공시/회사개황.
# Issue at https://opendart.fss.or.kr
DART_API_KEY=

# KIS 시세/재무 전용 실전(real) 도메인 자격증명.
# 매매/잔고 흐름(DB 모의 키)과 분리. 둘 다 채워야 시세/재무가 연동됨.
KIS_QUOTE_APP_KEY=
KIS_QUOTE_APP_SECRET=

# KIS 시세/재무 호출 도메인 (기본값: 실전 도메인). 비워두면 application.yml 기본값 사용.
KIS_QUOTE_BASE_URL=https://openapi.koreainvestment.com:9443
