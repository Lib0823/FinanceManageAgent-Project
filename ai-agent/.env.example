# Python Environment
PYTHONPATH=/app

# KIS API (모의투자)
KIS_MODE=VIRTUAL
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_ACCOUNT_NUMBER=your_account_number_here
KIS_ACCOUNT_PRODUCT_CODE=01

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financemanage
DB_USER=postgres
DB_PASSWORD=yourpassword

# Scheduler
PIPELINE_CRON=50 8 * * 1-5
PIPELINE_TIMEZONE=Asia/Seoul
PIPELINE_ENABLED=true

# Gemini AI (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# DART API (금융감독원 전자공시시스템)
DART_API_KEY=your_dart_api_key_here

# API Server (Spring Boot) — 내부 서비스 호출 (멀티유저 파이프라인)
# api-server 의 INTERNAL_API_KEY 와 동일한 값으로 맞춰야 함
API_SERVER_URL=http://api-server:7070
INTERNAL_API_KEY=change-this-to-match-api-server

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
